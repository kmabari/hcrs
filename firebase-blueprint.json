{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores membership details and credentials for HCRS Society members.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string" },
        "mobile": { "type": "string", "description": "Username (unique mobile number)" },
        "email": { "type": "string", "description": "Contact email and login credential." },
        "address": { "type": "string" },
        "district": { "type": "string" },
        "state": { "type": "string" },
        "pincode": { "type": "string" },
        "postOffice": { "type": "string" },
        "assemblyConstituency": { "type": "string" },
        "bloodGroup": { "type": "string" },
        "membershipType": { "type": "string", "enum": ["Annual", "Life"] },
        "photoUrl": { "type": "string", "description": "URL to profile photo in Firebase Storage" },
        "paymentProofUrl": { "type": "string", "description": "URL to payment screenshot in Firebase Storage" },
        "registrationDate": { "type": "string", "format": "date-time" },
        "membershipId": { "type": "string", "description": "Format: [State]/[District_Code]/[Constituency_Code]/[Serial_No]" },
        "status": { "type": "string", "enum": ["pending", "active", "offline"] },
        "isPaid": { "type": "boolean" },
        "isApproved": { "type": "boolean" },
        "isAdmin": { "type": "boolean" },
        "pin": { "type": "string", "description": "6-digit numeric password" }
      },
      "required": ["name", "mobile", "email", "district", "state", "pin"]
    },
    "SupportClaim": {
      "title": "Highrich Support Claim",
      "description": "Information collected for member support coordination regarding Highrich investments.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "membershipId": { "type": "string" },
        "userName": { "type": "string" },
        "userMobile": { "type": "string" },
        "userDistrict": { "type": "string" },
        "highrichId": { "type": "string" },
        "categories": { "type": "array" },
        "otherCategory": { "type": "string" },
        "categoryDetails": { "type": "object" },
        "noBreakup": { "type": "boolean" },
        "totalPaid": { "type": "number" },
        "totalReceived": { "type": "number" },
        "totalPending": { "type": "number" },
        "futurePreference": { "type": "string" },
        "hardshipStatus": { "type": "array" },
        "isEmergency": { "type": "boolean" },
        "priorityStatus": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["uid", "membershipId", "totalPaid", "totalReceived", "futurePreference"]
    },
    "DistrictQuota": {
      "title": "District Registration Quota",
      "description": "Defines the shared registration limits for a specific district.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "District Code (e.g., MLP, KKD)" },
        "districtName": { "type": "string" },
        "total": { "type": "integer" },
        "used": { "type": "integer" }
      },
      "required": ["id", "districtName", "total", "used"]
    },
    "OrgSettings": {
      "title": "Organization Settings",
      "description": "Stores site-wide configuration like contact details and about content.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "shortName": { "type": "string" },
        "aboutUs": { "type": "string" },
        "mission": { "type": "string" },
        "vision": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "website": { "type": "string" },
        "districtDetails": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    },
    "GalleryItem": {
      "title": "Gallery Item",
      "description": "An image in the organization gallery.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string" },
        "category": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["url", "category", "title"]
    },
    "SupportTicket": {
      "title": "Support Ticket",
      "description": "Customer support inquiries lodged automatically by the AI chatbot.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "memberName": { "type": "string" },
        "memberId": { "type": "string" },
        "phone": { "type": "string" },
        "issue": { "type": "string" },
        "aiSummary": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "resolved"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["memberName", "phone", "issue", "status"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Collection of HCRS Society members."
    },
    "districtQuotas": {
      "schema": "DistrictQuota",
      "description": "Shared registration quotas per district."
    },
    "claims": {
      "schema": "SupportClaim",
      "description": "Member support claims and investment details."
    },
    "settings": {
      "schema": "OrgSettings",
      "description": "Global organization settings document."
    },
    "gallery": {
      "schema": "GalleryItem",
      "description": "Collection of gallery images."
    },
    "support_tickets": {
      "schema": "SupportTicket",
      "description": "Automated helper chatbot tickets and notifications for operators."
    }
  }
}
